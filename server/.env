# ── Database ──────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/university_management

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ── Activation Codes (store hashed in production) ─────────────
SCHOOL_ADMIN_CODE=654321
DEPT_ADMIN_CODE=456789

# ── Server ────────────────────────────────────────────────────
PORT=5000
CLIENT_URL=http://localhost:5173
NODE_ENV=development
